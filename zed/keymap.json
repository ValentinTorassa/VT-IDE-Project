// VT IDE Project — Zed Keybindings
// Git workflow and AI shortcuts
[
  {
    "context": "Workspace",
    "bindings": {
      // ── AI Assistant ──────────────────────────────────────
      "cmd-shift-a": "assistant::ToggleFocus",
      "cmd-shift-i": "assistant::InlineAssist",

      // ── Git workflows ────────────────────────────────────
      "cmd-shift-g": "workspace::ToggleBottomDock",

      // ── Terminal ──────────────────────────────────────────
      "ctrl-`": "terminal_panel::ToggleFocus",

      // ── Navigation ────────────────────────────────────────
      "cmd-shift-o": "file_finder::Toggle",
      "cmd-shift-f": "workspace::NewSearch"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      // ── AI inline assist on selection ─────────────────────
      "cmd-k": "assistant::InlineAssist",

      // ── Quick actions ─────────────────────────────────────
      "cmd-shift-d": "editor::DuplicateLineDown",
      "cmd-shift-k": "editor::DeleteLine",
      "alt-up": "editor::MoveLineUp",
      "alt-down": "editor::MoveLineDown",

      // ── Multi-cursor ──────────────────────────────────────
      "cmd-d": "editor::SelectNext"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-`": "terminal_panel::ToggleFocus"
    }
  }
]
