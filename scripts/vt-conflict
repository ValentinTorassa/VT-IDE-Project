#!/usr/bin/env bash
# vt-conflict — AI-assisted merge conflict resolution
# Usage: vt-conflict [file]
set -euo pipefail

YELLOW='\033[1;33m'
CYAN='\033[1;36m'
GREEN='\033[1;32m'
RED='\033[1;31m'
DIM='\033[2m'
RESET='\033[0m'

show_help() {
  echo -e "${CYAN}vt-conflict${RESET} — AI merge conflict resolver"
  echo ""
  echo "Usage:"
  echo "  vt-conflict             # Show all conflicted files and resolve interactively"
  echo "  vt-conflict src/app.ts  # Resolve conflicts in a specific file"
  echo "  vt-conflict --help      # Show this help"
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  show_help
  exit 0
fi

for cmd in git claude; do
  if ! command -v "$cmd" &>/dev/null; then
    echo -e "${YELLOW}Missing dependency:${RESET} $cmd"
    exit 1
  fi
done

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo -e "${YELLOW}Not in a git repository${RESET}"
  exit 1
fi

# Find conflicted files
CONFLICTED=$(git diff --name-only --diff-filter=U 2>/dev/null)

if [[ -z "$CONFLICTED" ]]; then
  echo -e "${GREEN}No merge conflicts found${RESET}"
  exit 0
fi

echo -e "${RED}Conflicted files:${RESET}"
echo "$CONFLICTED" | while read -r f; do
  echo -e "  ${YELLOW}$f${RESET}"
done
echo ""

# If a specific file is provided, resolve just that one
TARGET="${1:-}"

if [[ -z "$TARGET" ]]; then
  echo -e "${DIM}Run: vt-conflict <file> to resolve a specific file${RESET}"
  echo ""
  # Pick the first conflicted file
  TARGET=$(echo "$CONFLICTED" | head -1)
  echo -e "${CYAN}Resolving first conflict: ${TARGET}${RESET}"
fi

if [[ ! -f "$TARGET" ]]; then
  echo -e "${YELLOW}File not found: ${TARGET}${RESET}"
  exit 1
fi

FILE_CONTENT=$(cat "$TARGET")

# Check for conflict markers
if ! grep -q "<<<<<<< " "$TARGET"; then
  echo -e "${GREEN}No conflict markers in ${TARGET}${RESET}"
  exit 0
fi

CONFLICT_COUNT=$(grep -c "<<<<<<< " "$TARGET")
echo -e "${CYAN}Found ${CONFLICT_COUNT} conflict(s) in ${TARGET}${RESET}"
echo ""

PROMPT="Resolve the merge conflicts in this file. The file contains git conflict markers (<<<<<<< , =======, >>>>>>>).

Rules:
- Output ONLY the resolved file content, no explanations before or after the code
- Remove ALL conflict markers
- Integrate changes from BOTH sides when possible
- Keep code style consistent
- After the resolved code, add a brief --- separator and explain what you kept from each side

File: ${TARGET}

Content:
${FILE_CONTENT}"

echo -e "${CYAN}AI resolving conflicts...${RESET}"
echo ""

RESOLVED=$(echo "$PROMPT" | claude --print 2>/dev/null || echo "$PROMPT" | claude -p 2>/dev/null)

echo "$RESOLVED"
echo ""
echo -e "${YELLOW}Apply this resolution to ${TARGET}? [y/N]${RESET}"
read -r CONFIRM

if [[ "$CONFIRM" =~ ^[Yy]$ ]]; then
  # Extract just the code (before the --- separator)
  echo "$RESOLVED" | sed '/^---$/,$d' > "$TARGET"
  echo -e "${GREEN}Resolved! Run 'git add ${TARGET}' to mark as resolved${RESET}"
else
  echo -e "${DIM}Resolution not applied${RESET}"
fi
