#!/usr/bin/env bash
# vt-diff — Show current diff with AI explanation
# Usage: vt-diff [--staged] [--branch main] [file...]
set -euo pipefail

YELLOW='\033[1;33m'
CYAN='\033[1;36m'
GREEN='\033[1;32m'
DIM='\033[2m'
RESET='\033[0m'

show_help() {
  echo -e "${CYAN}vt-diff${RESET} — AI-powered diff explanation"
  echo ""
  echo "Usage:"
  echo "  vt-diff                # Explain unstaged changes"
  echo "  vt-diff --staged       # Explain staged changes"
  echo "  vt-diff --branch main  # Explain changes vs a branch"
  echo "  vt-diff src/file.ts    # Explain changes in specific file"
  echo "  vt-diff --help         # Show this help"
}

DIFF_ARGS=""
LABEL="unstaged changes"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) show_help; exit 0 ;;
    --staged) DIFF_ARGS="--staged"; LABEL="staged changes"; shift ;;
    --branch) DIFF_ARGS="$2...HEAD"; LABEL="changes vs $2"; shift 2 ;;
    *) DIFF_ARGS="$DIFF_ARGS -- $1"; shift ;;
  esac
done

# Check dependencies
for cmd in git claude; do
  if ! command -v "$cmd" &>/dev/null; then
    echo -e "${YELLOW}Missing dependency:${RESET} $cmd"
    exit 1
  fi
done

# Check we're in a git repo
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo -e "${YELLOW}Not in a git repository${RESET}"
  exit 1
fi

DIFF=$(git diff $DIFF_ARGS)

if [[ -z "$DIFF" ]]; then
  echo -e "${DIM}No ${LABEL} found${RESET}"
  exit 0
fi

# Show stats first
echo -e "${CYAN}Diff stats (${LABEL}):${RESET}"
git diff --stat $DIFF_ARGS
echo ""

# Pretty diff with delta if available
if command -v delta &>/dev/null; then
  echo "$DIFF" | delta --side-by-side --width="$(tput cols)" 2>/dev/null | head -80
  echo ""
  echo -e "${DIM}(showing first 80 lines of formatted diff)${RESET}"
  echo ""
fi

echo -e "${CYAN}AI Explanation:${RESET}"
echo ""

PROMPT="Explain this git diff concisely:

1. **Summary** — One sentence: what changed and the likely intent
2. **Key changes** — Bullet list of important modifications
3. **Impact** — What parts of the system are affected
4. **Risk** — Low/Medium/High

Diff:
$(echo "$DIFF" | head -400)"

echo "$PROMPT" | claude --print 2>/dev/null || echo "$PROMPT" | claude -p 2>/dev/null
