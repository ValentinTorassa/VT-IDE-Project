#!/usr/bin/env bash
# vt-pr — Fetch and summarize a PR with AI
# Usage: vt-pr [PR_NUMBER] [--repo owner/repo]
set -euo pipefail

YELLOW='\033[1;33m'
CYAN='\033[1;36m'
GREEN='\033[1;32m'
DIM='\033[2m'
RESET='\033[0m'

show_help() {
  echo -e "${CYAN}vt-pr${RESET} — AI-powered PR summary"
  echo ""
  echo "Usage:"
  echo "  vt-pr                    # List open PRs in current repo"
  echo "  vt-pr 42                 # Summarize PR #42"
  echo "  vt-pr 42 --repo org/repo # Summarize PR #42 from specific repo"
  echo "  vt-pr --help             # Show this help"
}

# Parse args
PR_NUMBER=""
REPO_FLAG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) show_help; exit 0 ;;
    --repo) REPO_FLAG="--repo $2"; shift 2 ;;
    *) PR_NUMBER="$1"; shift ;;
  esac
done

# Check dependencies
for cmd in gh jq claude; do
  if ! command -v "$cmd" &>/dev/null; then
    echo -e "${YELLOW}Missing dependency:${RESET} $cmd"
    exit 1
  fi
done

# If no PR number, list open PRs
if [[ -z "$PR_NUMBER" ]]; then
  echo -e "${CYAN}Open PRs:${RESET}"
  gh pr list $REPO_FLAG --limit 20
  echo ""
  echo -e "${DIM}Run: vt-pr <number> to summarize a PR${RESET}"
  exit 0
fi

echo -e "${CYAN}Fetching PR #${PR_NUMBER}...${RESET}"

# Fetch PR data
PR_DATA=$(gh pr view "$PR_NUMBER" $REPO_FLAG --json title,body,author,state,additions,deletions,changedFiles,reviews,comments,labels,baseRefName,headRefName)
PR_DIFF=$(gh pr diff "$PR_NUMBER" $REPO_FLAG 2>/dev/null || echo "Could not fetch diff")

PR_TITLE=$(echo "$PR_DATA" | jq -r '.title')
PR_AUTHOR=$(echo "$PR_DATA" | jq -r '.author.login')
PR_STATE=$(echo "$PR_DATA" | jq -r '.state')
PR_ADDS=$(echo "$PR_DATA" | jq -r '.additions')
PR_DELS=$(echo "$PR_DATA" | jq -r '.deletions')
PR_FILES=$(echo "$PR_DATA" | jq -r '.changedFiles')
PR_BASE=$(echo "$PR_DATA" | jq -r '.baseRefName')
PR_HEAD=$(echo "$PR_DATA" | jq -r '.headRefName')

echo -e "${GREEN}$PR_TITLE${RESET}"
echo -e "${DIM}by $PR_AUTHOR | $PR_STATE | +$PR_ADDS -$PR_DELS | $PR_FILES files | $PR_HEAD -> $PR_BASE${RESET}"
echo ""

# Send to Claude for analysis
echo -e "${CYAN}Analyzing with AI...${RESET}"
echo ""

PROMPT="Analyze this pull request and provide:

1. **Summary** — What does this PR do and why? (2-3 sentences)
2. **Key Changes** — Bullet list of the most important modifications
3. **Risk Assessment** — Low/Medium/High with brief reasoning
4. **Review Notes** — Anything a reviewer should pay attention to

PR Title: $PR_TITLE
PR Author: $PR_AUTHOR
PR State: $PR_STATE
Changes: +$PR_ADDS -$PR_DELS across $PR_FILES files
Branch: $PR_HEAD -> $PR_BASE

PR Description:
$(echo "$PR_DATA" | jq -r '.body // "No description"')

Diff (truncated to first 500 lines):
$(echo "$PR_DIFF" | head -500)"

echo "$PROMPT" | claude --print 2>/dev/null || echo "$PROMPT" | claude -p 2>/dev/null
