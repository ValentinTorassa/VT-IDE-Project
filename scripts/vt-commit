#!/usr/bin/env bash
# vt-commit — Generate smart commit messages from staged changes
# Usage: vt-commit [--dry-run]
set -euo pipefail

YELLOW='\033[1;33m'
CYAN='\033[1;36m'
GREEN='\033[1;32m'
DIM='\033[2m'
RESET='\033[0m'

show_help() {
  echo -e "${CYAN}vt-commit${RESET} — AI commit message generator"
  echo ""
  echo "Usage:"
  echo "  vt-commit             # Generate and commit"
  echo "  vt-commit --dry-run   # Generate message without committing"
  echo "  vt-commit --help      # Show this help"
}

DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) show_help; exit 0 ;;
    --dry-run) DRY_RUN=true; shift ;;
    *) echo -e "${YELLOW}Unknown option: $1${RESET}"; show_help; exit 1 ;;
  esac
done

for cmd in git claude; do
  if ! command -v "$cmd" &>/dev/null; then
    echo -e "${YELLOW}Missing dependency:${RESET} $cmd"
    exit 1
  fi
done

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo -e "${YELLOW}Not in a git repository${RESET}"
  exit 1
fi

STAGED=$(git diff --staged)

if [[ -z "$STAGED" ]]; then
  echo -e "${YELLOW}No staged changes.${RESET} Stage files first with 'git add'"
  exit 1
fi

STATS=$(git diff --staged --stat)
echo -e "${CYAN}Staged changes:${RESET}"
echo -e "${DIM}${STATS}${RESET}"
echo ""

# Get recent commit style
RECENT=$(git log --oneline -5 2>/dev/null || echo "")

PROMPT="Generate a git commit message for these staged changes.

Rules:
- First line: imperative mood, under 72 chars, specific (e.g., 'Add OAuth2 login flow' not 'Update code')
- If needed, add a blank line then a body with bullet points explaining why
- Match the style of recent commits if possible
- Categorize: feat, fix, refactor, docs, test, chore
- Output ONLY the commit message, nothing else

Recent commits for style reference:
${RECENT}

Staged diff:
$(echo "$STAGED" | head -400)"

echo -e "${CYAN}Generating commit message...${RESET}"
echo ""

MSG=$(echo "$PROMPT" | claude --print 2>/dev/null || echo "$PROMPT" | claude -p 2>/dev/null)

echo -e "${GREEN}Proposed commit message:${RESET}"
echo "────────────────────────────────────────"
echo "$MSG"
echo "────────────────────────────────────────"
echo ""

if $DRY_RUN; then
  echo -e "${DIM}Dry run — not committing${RESET}"
  exit 0
fi

echo -e "${YELLOW}Commit with this message? [Y/n/e(dit)]${RESET}"
read -r CONFIRM

case "$CONFIRM" in
  [Nn]) echo -e "${DIM}Commit cancelled${RESET}" ;;
  [Ee]) git commit -e -m "$MSG" ;;
  *) git commit -m "$MSG" ; echo -e "${GREEN}Committed!${RESET}" ;;
esac
